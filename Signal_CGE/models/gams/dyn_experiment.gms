 AgBuTotOutSub_BL(t1)     = AgBuTotOutSub.L      ;
 AgBuTOTALx_BL(t1)        = AgBuTOTALx.L         ;
 AgBuTOTShr_BL(t1)        = AgBuTOTShr.L         ;
 TF_BL(ff,a,t1)           = TF.L(ff,a)           ;
 DTF_BL(t1)               = DTF.L                ;
 WF_BL(ff,t1)             = WF.L(ff)             ;
 FSI_BL(ins,ff,t1)        = FSI.L(ins,ff)        ; 
else

*----------------------------------------------------
*------ Get BaU results -----------------------------
*----------------------------------------------------

 ADFDSIM(ff,a,t,sim)      = ADFD_BL(ff,a,t)      ;
 INVESTSIM (t,sim)        = INVEST_BL(t)         ;
 KAPGOVSIM (t,sim)        = KAPGOV_BL(t)         ;
 KAPWORSIM (t,sim)        = KAPWOR_BL(t)         ;
 KAPREGSIM (w,t,sim)      = KAPREG_BL(w,t)       ;
 QINVSIM   (i,t,sim)      = QINV_BL(i,t)         ;
 QESIM     (c,t,sim)      = QE_BL(c,t)           ;
 QERSIM    (c,w,t,sim)    = QER_BL(c,w,t)        ;
 QMSIM     (c,t,sim)      = QM_BL(c,t)           ;
 PQDSIM    (c,t,sim)      = PQD_BL(c,t)          ;
 QMRSIM    (w,c,t,sim)    = QMR_BL(w,c,t)        ;
 EGSIM     (t,sim)        = EG_BL(t)             ;
 YGSIM     (t,sim)        = YG_BL(t)             ;
 qgdconstsim(c,t,sim)     = QGD_BL(c,t)          ;
 FTAXSIM   (t,sim)$t2(t)  = FTAX_BL(t)           ;
 FDSIM     (ff,a,t,sim)   = FD_BL(ff,a,t)        ;
 QVASIM    (a,t,sim)      = QVA_BL(a,t)          ;
 VVASIM    (a,t,sim)      = VVA_BL(a,t)          ;
 TFsim     (ff,a,t,sim)   = TF_BL(ff,a,t)        ;
 DTF_BL    (t)            = DTF_BL(t)            ;
 WFSIM(ff,t,sim)          = WF_BL(ff,t)          ;
 FSISIM(ins,ff,t,sim)     = FSI_BL(ins,ff,t)     ;
 AgBuRecurrSIM(c,t,sim)   = AgBuRecurr_BL(c,t)   ;
 AgBuInvestSIM(i,t,sim)   = AgBuInvest_BL(i,t)   ;
 AgBuInpSubSIM(ff,a,t,sim)= AgBuInpSub_BL(ff,a,t);
 AgBuOutSubSIM(a,t,sim)   = AgBuOutSub_BL(a,t)   ;
 AgBuTotRecurrSIM(t,sim)  = AgBuTotRecurr_BL(t)  ;
 AgBuTotInvestSIM(t,sim)  = AgBuTotInvest_BL(t)  ;
 AgBuTotInpSubSIM(t,sim)  = AgBuTotInpSub_BL(t)  ;
 AgBuTotOutSubSIM(t,sim)  = AgBuTotOutSub_BL(t)  ;
 AgBuTOTALxSIM(t,sim)     = AgBuTOTALx_BL(t)     ;
 AgBuTOTShrSIM(t,sim)     = AgBuTOTShr_BL(t)     ;
 tf01SIM(ff,a,t,sim1)     = 0                    ;


*-first include the closure file
$INCLUDE 50_Closure\%closureFile%

*- This should never come before the closure file!!!!
*------UPDATES FROM PREVIOUS PERIOD--------------
*--- Population
if(t2(t1),

*- Population change given demographics and migration drivers
$include 40_Dynamics\pop_update.inc

*- Capital Stock
$include 40_Dynamics\cap_update_1.inc
fmkt(k)  = SUM(a, FD.L(k,a)) - SUM(ins,FSI.L(ins,k)) ;

*- Updating the parameter calibrations
$INCLUDE 40_Dynamics\parm_update.inc

*--- Migration
$if set mig_module $INCLUDE 40_dynamics\migration_update.inc

else
*- this is for proper update of capital
 FD.FX(k,a) = FD0(k,a);
 POPN0(h) = SUM(l,FSI0(h,l)) ;
 popnp(h) = popn0(h) ;
);

*-Replicate baseline calibration
*---  ---- GDP Growth
 GDP.LO            = -inf ;
 GDP.UP            = +inf ;

 ADFAGfADJ.FX("fva")  = ADFAGfADJ_BL("fva",t1);
*---  ---- Investment Growth
 INVEST.FX            = INVESTSIM(t1,sim1) ;
*---  ---- Internal Balance
 KAPGOV.FX            = KAPGOVSIM(t1,sim1);
*---  ---- External Balance
 KAPREG.FX(w)         = KAPREGSIM(w,t1,sim1) ;

*- remove negative investments & rescale
 ioqinvdSIM(c,i,t1,sim1)$( t2(t1) AND ioqinvdSIM(c,i,t1,sim1)<0)= 0;
 ioqinvdSIM(c,i,t1,sim1) $( t2(t1) AND SUM(cp, ioqinvd(cp,i)))= ioqinvdSIM(c,i,t1,sim1)/SUM(cp, ioqinvdSIM(cp,i,t1,sim1));
 ioqinvd(c,i)     =  ioqinvdSIM(c,i,t1,sim1);

*-------------------------------------------------
*- SHOCKS HERE -----------------------------------
*-------------------------------------------------
tmb(w,c) = TMSIM(w,c,t1,sim1)  ;
PWM.FX(c) =  PWMSIM(c,t1,sim1) ;
  
*------ Solve statement ---------------------------------------------
 demetra.optfile     = 6;
* Option Solprint=Off;
 OPTION DECIMALS = 6 ;
 Options limrow=100,limcol=100;
 option iterlim = 1000 ;
 Solve demetra Using MCP ;
*-end if statement
);

*-if base scenario cannot replicate BaU stop the solutions

*- Assigning levels for baseline results
$include 60_Report\resassign.inc

*-------- 6. Terminating loops ----------------------------------------

*- end loop over t
 } ;

*-if base scenario cannot replicate BaU stop the solutions
if(BaUFlag(sim1)=2,

baseCheck(resVar,sac,sacp,sacpp,sacppp,t1,"Base")$result("Level",resVar,sac,sacp,sacpp,sacppp,t1,"BaU")
                                          = result("Level",resVar,sac,sacp,sacpp,sacppp,t1,"Base")
                                                - result("Level",resVar,sac,sacp,sacpp,sacppp,t1,"BaU");
baseCheck(resVar,sac,sacp,sacpp,sacppp,t1,sim)$(ABS(baseCheck(resVar,sac,sacp,sacpp,sacppp,t1,sim)) LT 1E-7)=0
)

*- write BaU results to a gdx file
if(BaUFlag(sim1)=1,
Execute_Unload  '%gdxF%\%mode%_BaU',
 ADFAGfADJ_BL
 ADFD_BL
 INVEST_BL
 KAPGOV_BL
 KAPWOR_BL
 KAPREG_BL
 QINV_BL
 QE_BL
 QX_BL
 QXAC_BL
 QER_BL
 QM_BL
 QMR_BL
 QGD_BL
 EG_BL
 YG_BL
 FTAX_BL
 ITAXA_BL
 FD_BL
 QVA_BL
 VVA_BL
 AgBuRecurr_BL
 AgBuInvest_BL
 AgBuInpSub_BL
 AgBuOutSub_BL
 AgBuTotRecurr_BL
 AgBuTotInvest_BL
 AgBuTotInpSub_BL
 AgBuTotOutSub_BL
 AgBuTOTALx_BL
 AgBuTOTShr_BL
 TF_BL
 TXA_BL
 DTF_BL
 result
 FSI_BL
 PQD_BL
 MIGCONS_BL
;
);

*- end loop over sim
) ;

*-########### ANALYSIS OF BaU SCENARIO ###############################
$INCLUDE 60_Report\report.inc
*-################ END OF BaU CALIBRATION ############################
