 ADFAGfADJSIM(ff,t,sim) = ADFAGfADJ.L(ff) ;
 IADJTySIM(i,t,sim)     = IADJTy0(i)    ;
 ioqinvdSIM(c,i,t,sim)  = ioqinvd(c,i)  ;
 mu_extSIM(ff,a,t,sim1) = mu_ext(ff,a)  ;
 ioqttqqSIM(m,c,t,sim)  = ioqttqq0(m,c) ;
 betaSIM(cc,h,t,sim)    = beta(cc,h)    ;
 HOWORSIM(h,w,t,sim)    = HOWOR0(h,w)   ;
 GOVWORSIM(w,t,SIM)     = GOVWOR(w)     ;
 DTSSIM(t,sim)          = DTS0          ;
 DTXSIM(t,sim)          = DTX0          ;
 TYHADJSIM(t,sim)       = TYHADJ0       ;
 DTYHSIM(t,sim)         = DTYH0         ;
 DTYESIM(t,sim)         = DTYE0         ;
 ioqttqqSIM(m,c,t,sim)  = IOQTTQQ.L(m,c);
 PWMSIM(c,t,sim)        = PWM0(c)       ;
 
*-shocks parameters

*- normally all capital types receive investment under all simulations
 cap_sup_ad(f,i,sim,t)$map_f_i(f,i)            = 1  ;

*- remove negative investments & rescale
 ioqinvdSIM(c,i,t1,sim1)$( t2(t1) AND ioqinvdSIM(c,i,t1,sim1)<0)= 0;
 ioqinvdSIM(c,i,t1,sim1) $( t2(t1) AND SUM(cp, ioqinvd(cp,i)))= ioqinvdSIM(c,i,t1,sim1)/SUM(cp, ioqinvdSIM(cp,i,t1,sim1));


*-assign shocks

*TMSIM(w,c,t2,"test")   = 0.5*tmb(w,c)           ;
*PWMSIM("c_petr","2026","PETR") = 1.05 * PWM0("c_petr") ;
PWMSIM("c_mach","2026","test") = 0.922613 * PWM0("c_mach") ;


*-if BaU is not run then we have to load the BL data before starting

$ifthene.BaUnorun %runBau%=0
$gdxin %gdxF%\%mode%_BaU.gdx
$loaddc INVEST_BL
