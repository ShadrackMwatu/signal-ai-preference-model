$endif.BaUnorun

Parameter
closureSwap(sim)   parameter to manage closure sim specific swaps
Budget(t,sim)      annual investment in Agroparks
BudgetIncr(t,sim)  Percentage increase in investments
;

*-------------------------------------------------------------------
*- Migration
*-------------------------------------------------------------------
$if set mig_module $INCLUDE 40_Dynamics\migration_parm.inc

*-------- 5. Setting up & Running the time loop ---------------------------
Loop(sim1,
*- all updating is done here, the closure file just identifies which

*-Free all vars in closure file
$INCLUDE 40_Dynamics\reset.inc

*-Reset all dynamic parameters:
$INCLUDE 30_Calibration\parmcalib_assign.inc

* recalibrating emissions coeffiecients and initial emissions levels
$IF EXIST 10_gdx\emissions_Coeff_DEMETRA_%DEMETRA_REG%.gdx $BATINCLUDE 30_Calibration/calibEmissions.inc "assign"


*- Variables are fixed and which are flex
$INCLUDE 30_Calibration\varinit.inc

LOOP{t1,

if (BaUFlag(sim1)=1,

*----  include the closure file

$INCLUDE 50_Closure\%closureFile%

*------UPDATES FROM PREVIOUS PERIOD--------------
*- This should never come before the closure file!!!!

if(NOT t2(t1),
*- this is for proper update of capital
 FD.FX(k,a) = FD0(k,a);

else

*- Population change given demographics and migration drivers
$include 40_Dynamics\pop_update.inc

*- Capital Stock
$include 40_Dynamics\cap_update_1.inc

*- Updating the parameter calibrations
$INCLUDE 40_Dynamics\parm_update.inc

$if set mig_module $INCLUDE 40_dynamics\migration_update.inc

);

*-######## MACROECONOMIC AGGREGATES

*----- GDP Growth
 GDP.FX           = macro_BL(t1,"bgdp") ;
*----- Investment Growth
 INVEST.FX       = macro_BL(t1,"binv") ;
*----- Internal Balance
 KAPGOV.FX        = (KAPGOV0/GDP0)*macro_BL(t1,"bgdp") ;
*----- External Balance
* KAPWOR.FX       = (KAPWOR0/GDP0)*macro_BL(t1,"bgdp") ;
 KAPREG.FX(w)     = (KAPREG0(w)/GDP0)*macro_BL(t1,"bgdp") ;

 ioqinvd(c,i)     =  ioqinvdSIM(c,i,t1,sim1);


 demetra.optfile     = 6;

 OPTION DECIMALS = 6 ;
 Options limrow=100,limcol=0;
 option iterlim = 1000 ;
* demetra.optfile = 3 ;
* Option Solprint=off;
 Option Solprint=On ;
 Solve demetra Using MCP ;

$INCLUDE 30_Calibration\calibcheck_assign.inc

*-write paremeters to be carried to the sims to a _BL parameter
