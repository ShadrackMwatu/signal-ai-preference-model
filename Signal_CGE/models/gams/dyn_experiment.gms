*$SETGLOBAL experiment  experiment_SEN.xlsx

*$SETGLOBAL experiment  experiment_CIV.xlsx
*$SETGLOBAL experiment  experiment_TZA.xlsx

$SETGLOBAL closureFile dynamic.inc
*-this is added to the result file names
$SETGLOBAL Mode dyna
*- this is the standard set elements for the results files
$SETGLOBAL resElem t,sim
*-this is used to write the results in every iteration of loop
$SETGLOBAL resElem1  t1,sim1
$SETGLOBAL resElemBs  t1,"base"
$SETGLOBAL resElemBaU t1,"BaU"
$SETGLOBAL resElemTp  tp,sim1
$SETGLOBAL resElemTpre  tp-1,sim1
$SETGLOBAL resElemLastYear  '"2030",sim1'
$SETGLOBAL resElemBsLastYear  '"2030","base"'
$SETGLOBAL exp example
*-this controls if BaU sim is run(=1) or not (=0) manually
$SETGLOBAL runBaU  1
*-if bau gdx file does not exitst overwrite the above command
$if not exist %gdxF%\%mode%_BaU.gdx $SETGLOBAL runBaU 1


*######### select functional form for migration ########
* Select among three functional forms
* Variant 1 employs a constant elasticity functional form
* that governs migration
* - select V1 and elasthh = 0 for no migration
* the other two variants are employing transition matrices
* that are based on probability functions:
* Version 2 is a basic version and
* version 3 a more sophisticated setup employing a nested
* functional form

*Comment the line below out to activate the migration module.
$setglobal mig_module 1

$setglobal mig_Variant V1_constElast
*$setglobal mig_Variant V2_simple-prob
*$setglobal mig_Variant V3_nested-prob

*### select income/expenditure driver ###
$setglobal mig_Ydriver INSVA
*$setglobal mig_Ydriver HEXP


*-------- 1. Declare and Assign Sets ---------------------------


*- Only declare and assign sets needed throughout

*-~~~~ 1a. Time sets for the recursive dynamic timeline

SET

*- NB: when defining time periods ordering matters 01 to 09 the 10 to 19 etc
*t            time /2017*2050/
*t1(t)        periods to run  /2017*2030/
 
 t            time /2020*2050/
 t1(t)        periods to run  /2020*2030/
 t2(t)        All time except first year
 tsim(t)
 tlast        Last sim period
 ;

*- Assigning memberships to time sets
* t1(t)=YES;
* t1(t)$(ord(t) < 4)=YES;
 t2(t)$(t1(t) AND ord(t)>1) = yes;

*-find the last year in t1
Loop(t$(t1(t)),
tlast(t)=YES;
tlast(t-1)=NO;
);
* sim1(sim) = NO;
* sim1("bau") = YES;

*-~~~~ 1b. Declare Simulation and Other Sets
*- By including a "base case" in the SIM set a comparator is produced
SETS
*- Set for capital accumulation
 i1(i)                investment
 a1(a)                activities
*- Sets for elements of recursive dynamics
 educate(c)           commodities used for education services
 health(c)            commoditieis used for health services
 road(i)              investment used for rural road
*- Sets for simulations
 sim                  simulations
 sim1(sim)            current simulations actually done
 simr(sim)            reported simulations
 ffer(ff)             fertilizer commodities
 fseed(ff)            seeds commodities
 aagrh(a)             HPHC agricultural activities
*- Sets for closures
 clos                 Set of closure rules for each experiment
 clos1(clos)          Set of closure rules for each experiment
 sens                 Sensitivity
 sens1(sens)          Sensitivity
*- Sets for macrobaseline
 mbas                 macro categories
*- Sets linking types of capital (k) to investment types (i)
 map_k_i(ff,i)        mapping to factor type ff from investment type i
 map_i_k(i,ff)        mapping to investment type i from factor type ff
;


ALIAS (t,tp), (t1,t1p),(t2,t2p),(sens,sensp), (clos,closp), (a1,a1p);

*------- 2. Declare and Assign Parameters  -------------------------------
*- Only declare and assign sets needed throughout
Parameter
*- Capital mobility in response to returns

 demog0(h,*)          demographic elasticities
 mu_fact(ff,*)        Response of factors to various changes
 mu_k(ff,t)           Factor mobility parameter by type of factor

 mu_activ(a,*)        Response of activities to various changes
 mu_a(a,t)            Capital mobility parameter by activity

 mu_house(h,*)        Response of households to various changes

 transRate(k,t)       capital conversion ratio

 tradesh(c,*)

 closSwap(sim)      parameter for sim specific closure swaps

 BaUFlag(sim)      Parameter to flag BaU simulation (=1 for BaU)
;

*- declare parameters to store post=sim SAM
$SETGLOBAL samNo 3
$INCLUDE 30_Calibration\samchk_decl.inc

