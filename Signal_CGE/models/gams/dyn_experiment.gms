INVESTSIM(t1,sim)        = INVEST_BL(t1)      ;
KAPGOVSIM(t1,sim)        = KAPGOV_BL(t1)      ;
KAPWORSIM(t1,sim)        = KAPWOR_BL(t1)      ;
